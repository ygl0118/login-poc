# 複製本檔為 .env 後填入實際值（.env 不進版控）
# 切勿把真實帳密寫進本範例檔（它會進版控）。本地用 .env，CI 用 Repository variables。

# 目標登入站
BASE_URL=https://swag.live/?lang=zh-TW

# 測試帳號 / 密碼 —— 請填入你自己的值，勿提交真實憑證
LOGIN_USERNAME=your_test_username
LOGIN_PASSWORD=your_test_password

# 反向測試用的錯誤密碼（可自訂）
WRONG_PASSWORD=definitely_wrong_password_000

# 瀏覽器設定
HEADLESS=true
SLOW_MO=0
# 預設逾時（毫秒）
DEFAULT_TIMEOUT=15000
